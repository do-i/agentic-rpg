#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

export PYTHONWARNINGS="ignore::RuntimeWarning"

VENV="$SCRIPT_DIR/.venv"

usage() {
    echo "Usage: ./run <command> [args...]"
    echo ""
    echo "Commands:"
    echo "  setup         Create venv and install dependencies"
    echo "  play          Run the game"
    echo "  record        Run the game in record mode"
    echo "  replay        Playback a recording (./run replay <speed>)"
    echo "  test          Run tests (./run test [pytest args...])"
    echo "  validate      Run data validation"
    echo "  maps          Render interactive map-connections HTML and open it"
    echo "  maps-brave    Render interactive map-connections HTML and open it in Brave"
    echo "  map-editor    Launch the scenario map viewer/editor"
    echo "  rm_cache      List or delete generated cache artifacts"
    echo "  wangset       Export Wang terrain connection graphs from a TSX file"
    echo ""
}

cmd="${1:-}"
shift || true

if [[ "$cmd" != "setup" && "$cmd" != "rm_cache" && "$cmd" != "" && "$cmd" != "help" && "$cmd" != "--help" && "$cmd" != "-h" ]]; then
    if [[ ! -f "$VENV/bin/activate" ]]; then
        echo "Error: venv not found. Run './run setup' first."
        exit 1
    fi
    # shellcheck disable=SC1091
    source "$VENV/bin/activate"
fi

case "$cmd" in
    setup)
        python3 -m venv "$VENV"
        source "$VENV/bin/activate"
        pip install -e ".[dev]"
        echo "Setup complete."
        ;;
    record)
        exec python -m engine.main \
            --scenario ./rusted_kingdoms \
            --seed 1 \
            --mode record
        ;;
    play)
        exec python -m engine.main \
            --scenario ./rusted_kingdoms \
            --seed 1 \
            --mode normal
        ;;
    replay)
        exec python -m engine.main \
            --scenario ./rusted_kingdoms \
            --seed 1 \
            --mode playback \
            --playback-speed "$@"
        ;;
    test)
        exec python -m pytest "$@"
        ;;
    validate)
        exec "$SCRIPT_DIR/tests/tools/validate.py" "$@"
        ;;
    maps)
        OUT="${OUT:-$SCRIPT_DIR/maps_graph.html}"
        python "$SCRIPT_DIR/tools/visualize_maps.py" \
            --root "$SCRIPT_DIR/rusted_kingdoms" \
            --out "$OUT" "$@"
        if command -v xdg-open >/dev/null 2>&1; then
            xdg-open "$OUT" >/dev/null 2>&1 &
        fi
        ;;
    maps-brave)
        OUT="${OUT:-$SCRIPT_DIR/maps_graph.html}"
        python "$SCRIPT_DIR/tools/visualize_maps.py" \
            --root "$SCRIPT_DIR/rusted_kingdoms" \
            --out "$OUT" "$@"
        for bin in brave brave-browser brave-bin; do
            if command -v "$bin" >/dev/null 2>&1; then
                "$bin" "$OUT" >/dev/null 2>&1 &
                exit 0
            fi
        done
        echo "Error: Brave browser not found in PATH."
        exit 1
        ;;
    map-editor)
        exec python -m tools.map_editor --scenario ./rusted_kingdoms "$@"
        ;;
    rm_cache)
        exec python "$SCRIPT_DIR/tools/cache_buster.py" "$@"
        ;;
    wangset)
        exec python "$SCRIPT_DIR/tools/wangset-graph.py" "$@"
        ;;
    ""|help|--help|-h)
        usage
        ;;
    *)
        echo "Unknown command: $cmd"
        usage
        exit 1
        ;;
esac
