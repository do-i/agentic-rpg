#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

export PYTHONWARNINGS="ignore::RuntimeWarning"

VENV="$SCRIPT_DIR/.venv"

usage() {
    echo "Usage: ./run <command> [args...]"
    echo ""
    echo "Commands:"
    echo "  setup         Create venv and install dependencies"
    echo "  play          Run the game"
    echo "  record        Run the game in record mode"
    echo "  replay        Playback a recording (./run replay <speed>)"
    echo "  test          Run tests (./run test [pytest args...])"
    echo "  validate      Run data validation"
    echo "  map-editor    Launch the map editor web UI (builds frontend on first run)"
    echo "  map-editor-pygame  Launch the legacy pygame map viewer/editor"
    echo "  rm_cache      List or delete generated cache artifacts"
    echo "  wangset       Export Wang terrain connection graphs from a TSX file"
    echo ""
}

cmd="${1:-}"
shift || true

if [[ "$cmd" != "setup" && "$cmd" != "rm_cache" && "$cmd" != "" && "$cmd" != "help" && "$cmd" != "--help" && "$cmd" != "-h" ]]; then
    if [[ ! -f "$VENV/bin/activate" ]]; then
        echo "Error: venv not found. Run './run setup' first."
        exit 1
    fi
    # shellcheck disable=SC1091
    source "$VENV/bin/activate"
fi

case "$cmd" in
    setup)
        python3 -m venv "$VENV"
        source "$VENV/bin/activate"
        pip install -e ".[dev,editor]"
        echo "Setup complete."
        ;;
    record)
        exec python -m engine.main \
            --scenario ./rusted_kingdoms \
            --seed 1 \
            --mode record
        ;;
    play)
        exec python -m engine.main \
            --scenario ./rusted_kingdoms \
            --seed 1 \
            --mode normal
        ;;
    replay)
        exec python -m engine.main \
            --scenario ./rusted_kingdoms \
            --seed 1 \
            --mode playback \
            --playback-speed "$@"
        ;;
    test)
        exec python -m pytest "$@"
        ;;
    validate)
        exec python "$SCRIPT_DIR/tools/validate.py" --root ./rusted_kingdoms "$@"
        ;;
    map-editor)
        # Web UI (React Flow). The editor extras (fastapi/uvicorn) and the
        # built frontend are provisioned on first run.
        if ! python -c "import uvicorn" 2>/dev/null; then
            echo "Installing editor extras (first run)..."
            pip install -e ".[dev,editor]"
        fi
        if [[ ! -d "$SCRIPT_DIR/tools/map_editor_web/dist" ]]; then
            echo "Building web frontend (first run)..."
            (cd "$SCRIPT_DIR/tools/map_editor_web" && npm install && npm run build)
        fi
        exec python -m tools.map_editor --web --scenario ./rusted_kingdoms "$@"
        ;;
    map-editor-pygame)
        exec python -m tools.map_editor --scenario ./rusted_kingdoms "$@"
        ;;
    rm_cache)
        exec python "$SCRIPT_DIR/tools/cache_buster.py" "$@"
        ;;
    wangset)
        exec python "$SCRIPT_DIR/tools/wangset-graph.py" "$@"
        ;;
    ""|help|--help|-h)
        usage
        ;;
    *)
        echo "Unknown command: $cmd"
        usage
        exit 1
        ;;
esac
